# Agnes-1.5-Pro via ZenMux (OpenAI-compatible)
AGNES_API_KEY=your_zenmux_api_key_here

# Canvas LMS
CANVAS_URL=https://canvas.nus.edu.sg
CANVAS_TOKEN=your_canvas_token_here

# Gmail OAuth — place credentials.json in project root (downloaded from Google Cloud Console)
# token.json will be auto-generated on first run
# No env vars needed for Gmail auth

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Mock mode (set to "false" to use real APIs)
USE_MOCK=true
