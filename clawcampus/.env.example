# Agnes-1.5-Pro via ZenMux (OpenAI-compatible)
AGNES_API_KEY=your_zenmux_api_key_here

# Canvas LMS
CANVAS_URL=https://canvas.nus.edu.sg
CANVAS_TOKEN=your_canvas_token_here

# Outlook via Maton Gateway
MATON_API_KEY=your_maton_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Local timezone for digest/deals/spending windows
APP_TIMEZONE=Asia/Singapore

# Mock mode (set to "false" to use real APIs)
USE_MOCK=true
